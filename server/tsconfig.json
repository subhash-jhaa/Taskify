{
    "compilerOptions": {
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "./dist",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "allowJs": true,
        "typeRoots": [
            "./node_modules/@types"
        ]
    },
    "include": [
        "controllers/**/*.ts",
        "middleware/**/*.ts",
        "routes/**/*.ts",
        "utils/**/*.ts",
        "config/**/*.ts",
        "server.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "prisma.config.ts"
    ]
}